package com.info.clonedatacalculationsxx

import android.app.NotificationChannel
import android.app.NotificationManager
import android.content.Context
import android.os.Build
import android.os.Bundle
import android.view.View
import android.widget.Button
import android.widget.EditText
import android.widget.TextView
import android.widget.Toast
import androidx.core.app.NotificationCompat
import androidx.fragment.app.Fragment
import java.lang.Math.PI


class fragment_calculations : Fragment() {

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {

        val r = view.findViewById<EditText>(R.id.etR)
        val h = view.findViewById<EditText>(R.id.etH)
        val l = view.findViewById<EditText>(R.id.etL)
        val btn = view.findViewById<Button>(R.id.btnCalc)
        val tv = view.findViewById<TextView>(R.id.tvArea)

        btn.setOnClickListener {

            val R = r.text.toString().toDouble()
            val H = h.text.toString().toDouble()
            val L = l.text.toString().toDouble()

            val volume = (1.0 / 3.0) * PI * R * R * H
            val area = PI * R * (L + R)

            tv.text = "المساحة = $area"

            Toast.makeText(requireContext(), "الحجم = $volume", Toast.LENGTH_LONG).show()

            showNotification(volume)
        }
    }

    private fun showNotification(volume: Double) {

        val manager = requireContext().getSystemService(Context.NOTIFICATION_SERVICE) as NotificationManager

        val channelId = "cone_channel"

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            val channel = NotificationChannel(
                channelId,
                "Cone",
                NotificationManager.IMPORTANCE_DEFAULT
            )
            manager.createNotificationChannel(channel)
        }

        val notification = NotificationCompat.Builder(requireContext(), channelId)
            .setContentTitle("بيانات المخروط")
            .setContentText("الحجم = $volume")
            .setSmallIcon(android.R.drawable.ic_dialog_info)
            .build()

        manager.notify(1, notification)
    }
}
